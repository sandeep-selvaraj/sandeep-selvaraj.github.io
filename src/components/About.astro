---
interface Paper {
  title: string;
  url?: string;
}

interface EducationItem {
  years: string;
  degree: string;
  school: string;
  thesis?: string;
  papers?: Paper[];
  notes?: string;
}

interface ExperienceItem {
  years: string;
  role: string;
  company: string;
  companyUrl?: string;
  description?: string[];
  techstack?: string[];
}

interface Props {
  headline: string;
  paragraphs: string[];
  tags: string[];
  location?: string;
  ethnicity?: string;
  education?: EducationItem[];
  experience?: ExperienceItem[];
}

const { headline, paragraphs, tags, location, ethnicity, education = [], experience = [] } = Astro.props;
const details = [location, ethnicity].filter(Boolean).join(' \u00B7 ');
---

<section class="about" id="about">
  <div class="container">
    <div class="section-label scroll-reveal">
      <span class="section-label__number">01</span>
      <span class="section-label__text">About</span>
    </div>
    <div class="about__grid">
      <div class="about__intro scroll-reveal">
        <h2 class="about__headline">{headline}</h2>
      </div>
      <div class="about__body scroll-reveal" style="--delay: 0.15s">
        {details && <p class="about__detail"><strong>{details}</strong></p>}
        {paragraphs.map(p => <p>{p}</p>)}

        {experience.length > 0 && (
          <div class="about__subsection" id="experience">
            <div class="section-label scroll-reveal" style="margin-bottom: var(--space-sm);">
              <span class="section-label__number">02</span>
              <span class="section-label__text">Experience</span>
            </div>
            {experience.map(e => (
              <div class="about__timeline-item about__timeline-item--rich">
                <span class="about__timeline-years">{e.years}</span>
                <div class="about__timeline-main">
                  <strong>{e.role}</strong> &mdash; {e.companyUrl
                    ? <a href={e.companyUrl} target="_blank" rel="noopener"><strong><em>{e.company}</em></strong></a>
                    : <strong><em>{e.company}</em></strong>
                  }
                  {Array.isArray(e.description) && e.description.length > 0 && (
                    <ul class="about__timeline-desc">
                      {e.description.map(d => <li>{d}</li>)}
                    </ul>
                  )}
                  {e.techstack && e.techstack.length > 0 && (
                    <div class="about__techstack">
                      {e.techstack.map(t => <span class="about__tech-tag">{t}</span>)}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}

        {education.length > 0 && (
          <div class="about__subsection" id="education">
            <div class="section-label scroll-reveal" style="margin-bottom: var(--space-sm);">
              <span class="section-label__number">03</span>
              <span class="section-label__text">Education</span>
            </div>
            {education.map(e => (
              <div class="about__timeline-item about__timeline-item--rich">
                <span class="about__timeline-years">{e.years}</span>
                <div class="about__timeline-main">
                  <strong>{e.degree}</strong> &mdash; {e.school}
                  {e.thesis && (
                    <div class="about__timeline-detail">
                      <span class="about__timeline-label">Thesis</span>
                      <span>{e.thesis}</span>
                    </div>
                  )}
                  {e.papers && e.papers.length > 0 && (
                    <div class="about__timeline-detail">
                      <span class="about__timeline-label">Papers</span>
                      <ul class="about__papers">
                        {e.papers.map(p => (
                          <li>
                            {p.url
                              ? <a href={p.url} target="_blank" rel="noopener">{p.title}</a>
                              : <span>{p.title}</span>
                            }
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {e.notes && (
                    <div class="about__timeline-detail">
                      <span class="about__timeline-note">{e.notes}</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
      <div class="about__domains scroll-reveal" style="--delay: 0.25s">
        {tags.map(t => <div class="domain-tag">{t}</div>)}
      </div>
    </div>
  </div>
</section>
